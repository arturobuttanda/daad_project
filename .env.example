DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
# Puede ser un TNS name o cadena de conexión
DB_DSN=tu_dsn_o_nombre_de_tns
# Ruta al directorio del wallet (puede ser relativa a la raíz del proyecto)
WALLET_PATH=path/al/wallet
WALLET_PASSWORD=tu_password_wallet
# URL donde sirve el frontend (coincide con CORS)
FRONTEND_URL=http://localhost:5173
# Oracle Autonomous Database — Credenciales de conexión
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env
# NUNCA subas el archivo .env al repositorio (ya está en .gitignore).

# Usuario administrador de la base de datos
DB_USER=ADMIN

# Contraseña del usuario de la base de datos
DB_PASSWORD=tu_contraseña

# DSN / TNS name (ej: db2025_high, db2025_medium, db2025_low)
# Se resuelve automáticamente desde tnsnames.ora dentro del wallet
DB_DSN=nombre_de_tu_db_high

# Ruta local a la carpeta del Wallet descomprimido (relativa o absoluta)
# Si se omite, el script busca automáticamente en wallet/<carpeta_wallet>/
WALLET_LOCATION=wallet/Wallet_TU_WALLET

# Contraseña del archivo ewallet.p12 (si difiere de DB_PASSWORD)
# Opcional: por defecto se usa DB_PASSWORD si no se establece
WALLET_PASSWORD=
